# Copy this file to .env and fill in the values
# cp .env.example .env

# ── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=3000

# ── Data source API keys (server-side only) ───────────────────
# Required for Polygon.io source
POLYGON_API_KEY=

# Required for TwelveData source
TWELVEDATA_API_KEY=

# ── Vite / client-side (must be prefixed with VITE_) ─────────
# These are embedded into the browser bundle at build time.
# Rebuild after changing them.
# VITE_DEFAULT_SYMBOL=BTCUSDT
# VITE_DEFAULT_INTERVAL=1d
VITE_RIGHT_PAD_BARS=10
VITE_PRESET_ROTATION_ENABLED=false
VITE_PRESET_ROTATION_INTERVAL=180
